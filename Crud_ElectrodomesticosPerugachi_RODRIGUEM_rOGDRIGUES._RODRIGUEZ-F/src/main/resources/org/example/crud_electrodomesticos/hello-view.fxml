        </TableView>
        <Label layoutX="118.0" layoutY="28.0" text="SISTEMA DE GESTION DE ELECTRODOMÉSTICOS">
            <font>
                <Font name="Century" size="24.0" />
            </font>
        </Label>
        <Label fx:id="lblproducto" layoutX="83.0" layoutY="141.0" stylesheets="@estilos.css" text="Producto" />
        <Label fx:id="lblcantidad" layoutX="84.0" layoutY="209.0" text="Cantidad" />
