<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="antabla" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="586.0" prefWidth="899.0" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.crud_electrodomesticos.ElectrodomesticosController">
    <children>
        <TextField fx:id="nombre" layoutX="159.0" layoutY="137.0" prefHeight="38.0" prefWidth="211.0" promptText="Ingrese el nombre del producto" stylesheets="@estilos.css" />
        <TextField fx:id="stock" layoutX="159.0" layoutY="205.0" promptText="Cantidad " stylesheets="@estilos.css" />
        <Button fx:id="crear" layoutX="14.0" layoutY="390.0" mnemonicParsing="false" onAction="#crear" styleClass="cr" stylesheets="@estilos.css" text="CREAR" />
        <Button fx:id="leer" layoutX="77.0" layoutY="390.0" mnemonicParsing="false" onAction="#mostrar" stylesheets="@estilos.css" text="LEER" />
        <Button fx:id="actualizar" layoutX="124.0" layoutY="390.0" mnemonicParsing="false" onAction="#editar" stylesheets="@estilos.css" text="ACTUALIZAR" />
        <Button fx:id="eliminar" layoutX="218.0" layoutY="390.0" mnemonicParsing="false" onAction="#eliminar" stylesheets="@estilos.css" text="ELIMINAR" />
        <TableView fx:id="tabla" layoutX="411.0" layoutY="100.0" prefHeight="466.0" prefWidth="436.0" stylesheets="@estilos.css">
